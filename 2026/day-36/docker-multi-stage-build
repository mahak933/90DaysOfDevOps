# ---------- Stage 1: Builder ----------
FROM python:3.11-slim AS builder

WORKDIR /app

# Copy only requirements first (better caching)
COPY requirements.txt .

# Install dependencies into a custom folder
RUN pip install -r requirements.txt --target=/python-deps

# Copy application code
COPY app.py .


# ---------- Stage 2: Production ----------
FROM gcr.io/distroless/python3-debian12

WORKDIR /app

# Copy installed dependencies
COPY --from=builder /python-deps /python-deps

# Copy application
COPY --from=builder /app/app.py .

# Tell Python where dependencies are
ENV PYTHONPATH=/python-deps

# Distroless requires full python path
CMD ["app.py"]
